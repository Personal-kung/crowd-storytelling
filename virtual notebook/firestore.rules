rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: stories
    // Document ID: auto-generated
    // Fields:
    //   - title: string (required)
    //   - author: map (required)
    //     - name: string (required)
    //     - nationality: string (required)
    //     - flag: string (required)
    //     - bio: string (required)
    //   - pages: list (required)
    //     - content: string (required)
    //   - writingDirection: string (required, 'ltr' or 'rtl')
    //   - coverImage: string (required)
    //   - createdAt: timestamp (optional)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function isValidStory(data) {
      return data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.author is map &&
             data.author.name is string && data.author.name.size() > 0 &&
             data.author.nationality is string &&
             data.author.flag is string &&
             data.author.bio is string &&
             data.pages is list &&
             data.writingDirection in ['ltr', 'rtl'] &&
             data.coverImage is string;
    }

    match /stories/{storyId} {
      // Initially restricted: only authenticated users can read.
      // In a real app, you might want public read if stories are public.
      allow read: if true; // Stories are meant to be a public gallery
      allow create: if isAuthenticated() && isValidStory(request.resource.data);
      allow update: if isAuthenticated() && isValidStory(request.resource.data);
      allow delete: if false; // Only admins should delete
    }

    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
